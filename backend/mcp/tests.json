{
  "tests": [
    {
      "name": "Статус сервера",
      "method": "GET",
      "path": "/?action=status",
      "expectedStatus": 200,
      "expectedBody": {"status": "operational"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Список инструментов",
      "method": "GET",
      "path": "/?action=tools",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Список ключей",
      "method": "GET",
      "path": "/?action=keys",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "MCP initialize",
      "method": "POST",
      "path": "/",

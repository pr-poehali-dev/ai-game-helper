      "expectedBody": {"jsonrpc": "2.0"},
      "bodyMatcher": "partial"
    },
    {
      "name": "MCP tools/list",
      "method": "POST",
      "path": "/",
      "body": {"jsonrpc": "2.0", "id": 2, "method": "tools/list"},
      "expectedStatus": 200,
      "expectedBody": {"jsonrpc": "2.0"},
      "bodyMatcher": "partial"
    }
